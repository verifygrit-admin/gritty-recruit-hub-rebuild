# .env.example — environment variable schema for gritty-recruit-hub-rebuild
#
# Convention mirrored from sibling repo `grittyfb-marketing`:
#   - This file is a SCHEMA ONLY. It lists variable names + where to obtain
#     real values. It must NEVER contain real secrets.
#   - `.env` and `.env.local` are gitignored. Real local development values
#     live in `.env` (or `.env.local` for personal overrides) on each
#     workstation; production / preview values live in the Vercel dashboard.
#
# Vercel project for this repo:
#   Name : gritty-recruit-hub-rebuild
#   Path : Vercel dashboard → Team → Projects → gritty-recruit-hub-rebuild → Settings → Environment Variables
#   Note : This is a DIFFERENT Vercel project from grittyfb-marketing
#          (Vercel project `grittyfb-marketing`). Do not confuse the two.
#
# CI: GitHub Actions reads from repository secrets. Mirror values from the
# Vercel dashboard into GitHub repository secrets when adding a new variable.
#
# To bootstrap locally:
#   cp .env.example .env
#   then fill in real values from the Vercel dashboard or 1Password
#
# ---------------------------------------------------------------------------
# 1. Supabase — browser-facing (Vite-exposed; safe in client bundle)
# ---------------------------------------------------------------------------

# Project URL — same in all environments (project xyudnajzhuwdauwkwsbh).
VITE_SUPABASE_URL=https://xyudnajzhuwdauwkwsbh.supabase.co

# Anon key — public, but rotate via Supabase dashboard if compromised.
# Source: Supabase dashboard → Project Settings → API → anon key.
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# 2. Supabase — server-only (NEVER expose to the browser)
# ---------------------------------------------------------------------------

# Same value as VITE_SUPABASE_URL but read by Node scripts that don't go
# through Vite (scripts/, supabase functions invoked locally, vitest, etc.).
SUPABASE_URL=https://xyudnajzhuwdauwkwsbh.supabase.co

# Service-role key — bypasses RLS. NEVER commit, NEVER ship to the client.
# Required by: scripts/seed_users.js, scripts/bulk_import_students.js,
# scripts/backfill-hudl-avatars.js, scripts/provision-admin-users.js,
# tests/unit/schema.test.js, tests/integration/bulk-pds/rls.test.js (Sprint 026).
# Source: Supabase dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# Same anon key as VITE_SUPABASE_ANON_KEY, read by non-Vite scripts.
# Required by: scripts/scrape_camp_details_playwright.js,
# tests/integration/bulk-pds/rls.test.js (Sprint 026).
SUPABASE_ANON_KEY=

# Personal Access Token for the Supabase Management API (database/query,
# migrations, Edge Function deploys).
# Required by: scripts/migrate.js, scripts/deploy-ef.js,
# scripts/verify_idx_raw.js, scripts/verify_migrations_*.js
# Source: https://app.supabase.com/account/tokens (generate per operator).
SUPABASE_PAT=

# Project ref shorthand. Optional — falls back to parsing from
# VITE_SUPABASE_URL if absent. Set for clarity.
SUPABASE_PROJECT_REF=xyudnajzhuwdauwkwsbh

# ---------------------------------------------------------------------------
# 3. Playwright test accounts
# ---------------------------------------------------------------------------
# Used by: tests/*.spec.js (regression, coach-dashboard-tabs, admin-*,
#          grit-fit-*, home-restructure, student-masthead, cmg, etc.)
#          AND tests/e2e/bulk-pds/*.spec.js (Sprint 026).
#
# These are seeded accounts in the Supabase project — NOT real user accounts.
# Source: Vercel dashboard (project gritty-recruit-hub-rebuild) → Env Vars,
#         AND mirrored in GitHub Actions repository secrets for CI runs.
#
# NOTE: Sprint 026 Phase 1 surfaced a gap — TEST_ADMIN_EMAIL /
#       TEST_ADMIN_PASSWORD are consumed by tests/admin-pagination.spec.js
#       and tests/admin-tab-remediation.spec.js (pre-existing) plus the new
#       tests/e2e/bulk-pds/admin-bulk-pds-approval.spec.js, but were not
#       documented anywhere. This file closes that documentation gap.

TEST_STUDENT_EMAIL=
TEST_STUDENT_PASSWORD=

TEST_COACH_EMAIL=
TEST_COACH_PASSWORD=

TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=

# Optional Playwright base URL override. Defaults to https://app.grittyfb.com
# in tests/cmg.spec.js etc. when absent.
TEST_APP_URL=
PLAYWRIGHT_BASE_URL=

# ---------------------------------------------------------------------------
# 4. Email — Resend (Sprint 026 notify-bulk-pds-event Edge Function)
# ---------------------------------------------------------------------------
# When ABSENT: notify-bulk-pds-event EF degrades gracefully — logs
#   "EMAIL_DISABLED: <event_type> to=<csv> subject=\"<subject>\"" lines
#   and returns { success: true, emails_disabled: true }. Lifecycle
#   (submission / approval / rejection) does NOT block on email.
# When PRESENT: emails fire via Resend API for the three event types.
#
# Source: https://resend.com/api-keys — generate per Vercel environment.
# Set in: Supabase Edge Function environment (Supabase dashboard →
#         Project Settings → Edge Functions → Secrets). The EF runtime
#         reads Deno.env.get('RESEND_API_KEY'); it is NOT a Vercel runtime
#         var for this EF — Vercel hosts the SPA, Supabase hosts the EF.

RESEND_API_KEY=
